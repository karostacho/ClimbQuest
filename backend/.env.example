# Copy to .env and fill in for local development.
# Neon connection string, using the psycopg3 driver scheme and the pooled endpoint:
# postgresql+psycopg://<user>:<password>@<pooler-host>/<dbname>?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/climbquest

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me

JWT_EXPIRE_MINUTES=10080
ENVIRONMENT=development
